        "outbound": "🏠 私有網絡"
      },
      {
        "rule_set": "rs-ai",
        "outbound": "💬 AI 服務"
      },
      {
        "rule_set": "ip-telegram",
        "outbound": "🚀 節點選擇"
      },
      {
        "rule_set": "rs-apple",
        "outbound": "🍎 蘋果服務"
