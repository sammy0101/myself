{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers":[
      {
        "tag": "remote-dns",
        "address": "8.8.8.8",
        "detour": "🚀 節點選擇"
      },
      {
        "tag": "local-dns",
        "address": "local",
        "detour": "DIRECT"
      },
      {
        "tag": "block",
        "address": "rcode://success"
      }
    ],
    "rules":[
      {
        "clash_mode": "Direct",
        "server": "local-dns"
      },
      {
        "clash_mode": "Global",
        "server": "remote-dns"
      },
      {
        "rule_set": "rs-ads",
        "server": "block"
      },
      {
        "rule_set":[
          "rs-cn",
          "rs-private",
          "rs-apple"
        ],
        "server": "local-dns"
      }
    ],
    "final": "remote-dns",
    "strategy": "ipv4_only",
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/15",
      "inet6_range": "fc00::/18"
    }
  },
  "inbounds":[
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "fd00::1/126",
      "stack": "system",
      "auto_route": true,
      "strict_route": true,
      "sniff": true
    }
  ],
  "outbounds":[
    {
      "type": "selector",
      "tag": "🚀 節點選擇",
      "outbounds":[
        "⚡ 自動選擇",
        "DIRECT"
      ]
    },
    {
      "type": "urltest",
      "tag": "⚡ 自動選擇",
      "outbounds":[],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50
    },
    {
      "type": "selector",
      "tag": "💬 AI 服務",
      "outbounds":[
        "⚡ 自動選擇",
        "🚀 節點選擇"
      ]
    },
    {
      "type": "selector",
      "tag": "🍎 蘋果服務",
      "outbounds":[
        "DIRECT",
        "🚀 節點選擇"
      ]
    },
    {
      "type": "selector",
      "tag": "🇨🇳 國內服務",
      "outbounds":[
        "DIRECT",
        "🚀 節點選擇"
      ]
    },
    {
      "type": "selector",
      "tag": "🏠 私有網絡",
      "outbounds":[
        "DIRECT"
      ]
    },
    {
      "type": "selector",
      "tag": "🐟 漏網之魚",
      "outbounds":[
        "🚀 節點選擇",
        "DIRECT"
      ]
    },
    {
      "type": "selector",
      "tag": "🛑 廣告攔截",
      "outbounds":[
        "REJECT",
        "DIRECT"
      ]
    },
    {
      "type": "direct",
      "tag": "DIRECT"
    },
    {
      "type": "block",
      "tag": "REJECT"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    }
  ],
  "route": {
    "rule_set":[
      {
        "type": "remote",
        "tag": "rs-ai",
        "format": "binary",
        "url": "https://github.com/sammy0101/myself/raw/refs/heads/main/geosite_ai_hk_proxy.srs",
